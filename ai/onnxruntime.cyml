# onnxruntime — ONNX model inference runtime
#
# BLFS / AI Stack

[package]
name = "onnxruntime"
version = "1.24.4"
description = "onnxruntime — Cross-platform ONNX model inference runtime"
license = "MIT"
groups = ["ai", "ml", "inference"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/microsoft/onnxruntime/archive/refs/tags/v1.24.4.tar.gz"
sha256 = "0cf4d2ee4392fbb8aedaabc6b2ba11b4a680d1071fa4f75546c2289ca5b404cf"
patches = []

[depends]
runtime = ["glibc", "openblas"]
build = ["gcc", "make", "pkgconf", "cmake"]

[build]
pre_build = ""
configure = """
mkdir -p build && cd build && \
cmake .. -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release
"""
make = "cd build && make -j$(nproc)"
check = "cd build && make test || true"
install = "cd build && make DESTDIR=$PKG install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
