# nccl — NVIDIA Collective Communications Library
#
# BLFS / AI Stack

[package]
name = "nccl"
version = "2.29.7"
description = "nccl — NVIDIA Collective Communications Library for multi-GPU and multi-node communication"
license = "BSD-3-Clause"
groups = ["ai", "ml", "gpu", "nvidia"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/NVIDIA/nccl/archive/refs/tags/v2.29.7-1.tar.gz"
sha256 = "e67239212c395bfdb398a7519491840d06fdf6b599c299f97c7ed0109777bba1"
patches = []

[depends]
runtime = ["glibc", "nvidia-cuda-toolkit"]
build = ["gcc", "make", "pkgconf"]

[build]
pre_build = ""
configure = ""
make = "make -j$(nproc) src.build"
check = ""
install = "make PREFIX=/usr DESTDIR=$PKG install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
