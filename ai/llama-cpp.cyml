# llama-cpp — High-performance LLM inference in C/C++
#
# BLFS / AI Stack

[package]
name = "llama-cpp"
version = "b8815"
description = "llama-cpp — High-performance LLM inference engine in C/C++"
license = "MIT"
groups = ["ai", "ml", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ggml-org/llama.cpp/archive/refs/tags/b8815.tar.gz"
sha256 = "e1420afe155cd6ebce83e7fbddd36ee2f16978fa66accc2a19e37de50e9606ae"
patches = []

[depends]
runtime = ["glibc", "openblas"]
build = ["gcc", "make", "pkgconf", "cmake"]

[build]
pre_build = ""
configure = """
mkdir -p build && cd build && \
cmake .. -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release \
  -DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS
"""
make = "cd build && make -j$(nproc)"
check = "cd build && make test || true"
install = "cd build && make DESTDIR=$PKG install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
