# vllm — High-throughput LLM serving engine
#
# BLFS / AI Stack

[package]
name = "vllm"
version = "0.23.0"
description = "vllm — High-throughput LLM serving engine with PagedAttention"
license = "Apache-2.0"
groups = ["ai", "ml", "llm", "serving"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/vllm-project/vllm/archive/refs/tags/v0.23.0.tar.gz"
sha256 = "a32a008b8fc05a45ab9fe8c65ac3e7e8bf6eb480efa935e3182d921d83cb95e0"
patches = []

[depends]
runtime = ["python", "python-pytorch", "python-transformers"]
build = ["python"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = "pip install --prefix=/usr --root=$PKG --no-deps ."
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
