# vllm — High-throughput LLM serving engine
#
# BLFS / AI Stack

[package]
name = "vllm"
version = "0.21.0"
description = "vllm — High-throughput LLM serving engine with PagedAttention"
license = "Apache-2.0"
groups = ["ai", "ml", "llm", "serving"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/vllm-project/vllm/archive/refs/tags/v0.21.0.tar.gz"
sha256 = "2d4bc9f472437e29f3d37918eebe7d6cd6d15e076995fb98ee0edbbb6e533959"
patches = []

[depends]
runtime = ["python", "python-pytorch", "python-transformers"]
build = ["python"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = "pip install --prefix=/usr --root=$PKG --no-deps ."
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
