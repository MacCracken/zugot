# vllm — High-throughput LLM serving engine
#
# BLFS / AI Stack

[package]
name = "vllm"
version = "0.19.0"
description = "vllm — High-throughput LLM serving engine with PagedAttention"
license = "Apache-2.0"
groups = ["ai", "ml", "llm", "serving"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/vllm-project/vllm/archive/refs/tags/v0.19.0.tar.gz"
sha256 = "619446480b4aec7bd39e0163467c87914ce9d7131b13db335db75de051f8863a"
patches = []

[depends]
runtime = ["python3", "python-pytorch", "python-transformers"]
build = ["python3", "pip"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = "pip install --prefix=/usr --root=$PKG --no-deps ."
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
