# rocm — AMD ROCm GPU compute platform
#
# BLFS / AI Stack

[package]
name = "rocm"
version = "7.2.1"
description = "rocm — AMD ROCm open-source GPU compute platform"
license = "MIT"
groups = ["ai", "ml", "gpu", "amd"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ROCm/ROCm/archive/refs/tags/rocm-7.2.1.tar.gz"
sha256 = "1471d05c17aae447b7c09d01c91ffdf928c2b90a8f7fc7a3f6abf7f5ddced245"
patches = []

[depends]
runtime = ["glibc", "cmake"]
build = ["gcc", "make", "pkgconf", "cmake"]

[build]
pre_build = ""
configure = """
mkdir -p build && cd build && \
cmake .. -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release
"""
make = "cd build && make -j$(nproc)"
check = "cd build && make test || true"
install = "cd build && make DESTDIR=$PKG install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
