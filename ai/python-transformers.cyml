# python-transformers — HuggingFace Transformers library
#
# BLFS / AI Stack

[package]
name = "python-transformers"
version = "5.5.4"
description = "python-transformers — HuggingFace Transformers for state-of-the-art NLP and ML"
license = "Apache-2.0"
groups = ["ai", "ml", "python", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/huggingface/transformers/archive/refs/tags/v5.5.4.tar.gz"
sha256 = "d9d5a35421d6e6b533b43f5766564ba1e89ee9b1b5f60230546ff6c4a1bef7eb"
patches = []

[depends]
runtime = ["python", "python-pytorch", "python-numpy"]
build = ["python", "pip"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = "pip install --prefix=/usr --root=$PKG --no-deps ."
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
