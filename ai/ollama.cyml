# ollama — Local LLM runner and model manager
#
# BLFS / AI Stack

[package]
name = "ollama"
version = "0.20.7"
description = "ollama — Local LLM runner and model manager"
license = "MIT"
groups = ["ai", "ml", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ollama/ollama/archive/refs/tags/v0.20.7.tar.gz"
sha256 = "bec362ceeb19226856fa250e583effdfcfd9d5e394711dd21eb80e68659644ea"
patches = []

[depends]
runtime = ["glibc"]
build = ["go"]

[build]
pre_build = ""
configure = ""
make = "go build -o ollama ."
check = "go test ./... || true"
install = "install -Dm755 ollama $PKG/usr/bin/ollama"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
