# ollama — Local LLM runner and model manager
#
# BLFS / AI Stack

[package]
name = "ollama"
version = "0.24.0"
description = "ollama — Local LLM runner and model manager"
license = "MIT"
groups = ["ai", "ml", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ollama/ollama/archive/refs/tags/v0.24.0.tar.gz"
sha256 = "a97e4a545cb08ed0343f97dc964be49f707b8404f1c2e29ec1338ec96b556eb2"
patches = []

[depends]
runtime = ["glibc"]
build = ["go"]

[build]
pre_build = ""
configure = ""
make = "go build -o ollama ."
check = "go test ./... || true"
install = "install -Dm755 ollama $PKG/usr/bin/ollama"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
