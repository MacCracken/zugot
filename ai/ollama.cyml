# ollama — Local LLM runner and model manager
#
# BLFS / AI Stack

[package]
name = "ollama"
version = "0.30.8"
description = "ollama — Local LLM runner and model manager"
license = "MIT"
groups = ["ai", "ml", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ollama/ollama/archive/refs/tags/v0.30.8.tar.gz"
sha256 = "9f3531305be8c1dcb00c9ad0a794b5916246a98c56796dc8ba69108fa2196369"
patches = []

[depends]
runtime = ["glibc"]
build = ["go"]

[build]
pre_build = ""
configure = ""
make = "go build -o ollama ."
check = "go test ./... || true"
install = "install -Dm755 ollama $PKG/usr/bin/ollama"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
