# ollama — Local LLM runner and model manager
#
# BLFS / AI Stack

[package]
name = "ollama"
version = "0.20.2"
description = "ollama — Local LLM runner and model manager"
license = "MIT"
groups = ["ai", "ml", "llm"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/ollama/ollama/archive/refs/tags/v0.20.2.tar.gz"
sha256 = "53a8eb37cb99279d6d8f5e8c94cda3119119fb75f4f35a3b8cc39b0232478bef"
patches = []

[depends]
runtime = ["glibc"]
build = ["go"]

[build]
pre_build = ""
configure = ""
make = "go build -o ollama ."
check = "go test ./... || true"
install = "install -Dm755 ollama $PKG/usr/bin/ollama"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
