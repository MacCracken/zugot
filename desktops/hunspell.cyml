# Hunspell — Spell checker and morphological analyzer
#
# BLFS

[package]
name = "hunspell"
version = "1.7.3"
description = "Hunspell — Spell checker and morphological analyzer"
license = "LGPL-2.1-only"
groups = ["desktops", "libs"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/hunspell/hunspell/archive/refs/tags/v1.7.3.tar.gz"
sha256 = "933be3dac6fd55f6e752331a170efb7e33800e40fae1156d8434cc8c85379a1b"
patches = []

[depends]
runtime = ["glibc", "ncurses"]
build = ["gcc", "make", "autoconf", "automake", "libtool", "pkgconf"]

[build]
pre_build = "autoreconf -vfi"
configure = "./configure --prefix=/usr --disable-static"
make = "make -j$(nproc)"
check = "make check || true"
install = "make DESTDIR=$PKG install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
