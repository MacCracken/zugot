# hyprcursor — Hyprland cursor theme format + library
#
# BLFS

[package]
name = "hyprcursor"
version = "0.1.13"
description = "hyprcursor — Hyprland cursor theme format and renderer"
license = "BSD-3-Clause"
groups = ["desktops", "libs"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/hyprwm/hyprcursor/archive/refs/tags/v0.1.13.tar.gz"
sha256 = "82af8b2ce27242ffdd6baebaa71b3f6c8665dc25c52bfcfccc16912622896af8"
patches = []

[depends]
runtime = ["cairo", "librsvg", "libzip", "tomlplusplus"]
build = ["gcc", "make", "cmake", "ninja", "pkgconf"]

[build]
pre_build = ""
configure = """
cmake -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release
"""
make = "cmake --build build --parallel"
check = ""
install = "DESTDIR=$PKG cmake --install build"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
