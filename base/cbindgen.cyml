# cbindgen — Rust-to-C binding generator
# Used by Firefox, Servo. Installed via cargo.

[package]
name = "cbindgen"
version = "0.29.2"
description = "cbindgen — Generate C bindings for Rust libraries"
license = "MPL-2.0"
groups = ["base", "build", "rust"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/mozilla/cbindgen/archive/refs/tags/0.29.2.tar.gz"
sha256 = "e2e8b044662804ef55c075ffca03da1d69c443d4749590cb29f03e8588ba49d1"
patches = []

[depends]
runtime = ["glibc"]
build = ["rust"]

[build]
pre_build = ""
configure = ""
make = "cargo build --release"
check = "cargo test || true"
install = "install -Dm755 target/release/cbindgen $PKG/usr/bin/cbindgen"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
