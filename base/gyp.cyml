# GYP — Generate Your Projects (Chromium's build-config generator)
# NSS and some other Google-maintained projects still use GYP.
# Upstream maintenance moved from Chromium to nodejs/gyp-next.
#
# BLFS

[package]
name = "gyp"
version = "0.22.2"
description = "GYP — Generate Your Projects build-config generator (gyp-next fork)"
license = "BSD-3-Clause"
groups = ["base", "build", "tier2"]
release = 1
arch = "any"

[source]
url = "https://github.com/nodejs/gyp-next/archive/refs/tags/v0.22.2.tar.gz"
sha256 = "eec4d9ca36028a28bffa6313fb7db51d664f06f49387cb734369777a55730d4d"
patches = []

[depends]
runtime = ["python"]
build = ["python"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = "python -m pip install --prefix=/usr --root=$PKG --no-deps ."
post_install = ""

[security]
hardening = []
cflags = ""
ldflags = ""
