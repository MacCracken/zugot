# Phylax — Threat detection and security scanning engine for AGNOS
# YARA-compatible rules, entropy analysis, magic bytes, ML classification,
# LLM triage via hoosh, fanotify real-time scanning.
#
# Name: Phylax (Greek: guardian, watchman)
# Bin: phylax (CLI + daemon mode)
# Lang: Cyrius (was Rust; 1.0.x is the Cyrius rewrite)
#
# Status: Released — v1.1.1.

[package]
name = "phylax"
version = "1.1.1"
description = "Phylax — AI-native threat detection engine"
license = "GPL-3.0-only"
groups = ["security", "system", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/phylax"
release_asset = "phylax-*-x86_64-linux"
sha256 = "fc694a5177cd436236a2c3395b3054a91dd9bf99424d6d1cced58aff9f1d41e5"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "security"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["security", "threat-detection", "yara", "scanner", "antivirus", "ai", "rust"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = true
data_dir = "~/.phylax/"

[[marketplace.sandbox.landlock]]
path = "~/.phylax/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/"
access = "ro"

[marketplace.sandbox.network]
allowed = ["127.0.0.1:8088", "127.0.0.1:8090"]

[build]
make = ""
check = ""
install = """
mkdir -p $PKG/usr/bin
install -Dm755 phylax-*-x86_64-linux $PKG/usr/bin/phylax
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
