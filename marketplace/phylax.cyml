# Phylax — Threat detection and security scanning engine for AGNOS
# YARA-compatible rules, entropy analysis, magic bytes, ML classification,
# LLM triage via hoosh, fanotify real-time scanning.
#
# Name: Phylax (Greek: guardian, watchman)
# Bin: phylax (CLI + daemon mode)
#
# Status: Published — v0.5.0.

[package]
name = "phylax"
version = "0.5.0"
description = "Phylax — AI-native threat detection engine"
license = "GPL-3.0-only"
groups = ["security", "system", "rust"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/phylax"
release_asset = "phylax-*-linux-amd64.tar.gz"
sha256 = ""  # TODO: populate from release tarball

[depends]
runtime = ["glibc"]
build = ["rust"]

[marketplace]
category = "security"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["security", "threat-detection", "yara", "scanner", "antivirus", "ai", "rust"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = true
data_dir = "~/.phylax/"

[[marketplace.sandbox.landlock]]
path = "~/.phylax/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/"
access = "ro"

[marketplace.sandbox.network]
allowed = ["127.0.0.1:8088", "127.0.0.1:8090"]

[build]
make = "cargo build --release --workspace"
check = "cargo test --workspace"
install = """
mkdir -p $PKG/usr/bin
cp target/release/phylax $PKG/usr/bin/phylax
chmod +x $PKG/usr/bin/phylax

mkdir -p $PKG/usr/lib/systemd/system
cat > $PKG/usr/lib/systemd/system/phylax.service << 'EOF'
[Unit]
Description=Phylax Threat Detection Daemon
After=network.target daimon.service

[Service]
ExecStart=/usr/bin/phylax daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
