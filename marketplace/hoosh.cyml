# Hoosh — AI inference gateway for the AGNOS ecosystem
# Multi-provider LLM routing (14 backends), OpenAI-compatible API, token
# budgets, response caching, speech-to-text (whisper), hardware-aware
# model placement.
#
# Name: Hoosh (Persian: هوش — intelligence)
# CLI: hoosh serve --port 8088
# Lang: Cyrius (was Rust through 1.x; 2.x is the Cyrius rewrite — uses
#       sandhi stdlib module for TLS, no openssl link)
#
# Status: Released — v2.4.6.

[package]
name = "hoosh"
version = "2.4.6"
description = "Hoosh — AI inference gateway (14 LLM providers, OpenAI-compatible, token budgets)"
license = "GPL-3.0-only"
groups = ["tool", "library", "ai", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/hoosh"
release_asset = "hoosh-*-x86_64-linux"
sha256 = "b0d9e6b5d0b5260b03543016152d5b7b4dea7f7dd68499c62b430f0ce8639bc7"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "ai-platform"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["llm", "inference", "ai", "gateway", "openai", "ollama", "whisper", "token-budget", "caching", "rust"]
min_agnos_version = "2026.3.20"

[marketplace.sandbox]
seccomp_mode = "desktop"
network_access = true
allowed_hosts = [
    "localhost",
    "127.0.0.1",
    # Local backends
    "localhost:11434",  # Ollama
    "localhost:8080",   # llama.cpp
    "localhost:1234",   # LM Studio
    # Remote APIs
    "api.openai.com",
    "api.anthropic.com",
    "api.groq.com",
    "api.deepseek.com",
    "api.mistral.ai",
    "openrouter.ai",
    "generativelanguage.googleapis.com",
]
data_dir = "~/.hoosh/"

[[marketplace.sandbox.landlock]]
path = "~/.hoosh/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/tmp"
access = "rw"

# IPC with daimon
[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

# GPU device access for hardware detection
[[marketplace.sandbox.landlock]]
path = "/dev/dri"
access = "ro"

# Sysfs for ai-hwaccel probing
[[marketplace.sandbox.landlock]]
path = "/sys/class/"
access = "ro"

[marketplace.services]
ports = [8088]

[build]
make = ""
check = ""
install = """
mkdir -p $PKG/usr/bin
BIN=$(find . -maxdepth 1 -type f -name 'hoosh-*-x86_64-linux' | head -1)
install -Dm755 "$BIN" $PKG/usr/bin/hoosh
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
