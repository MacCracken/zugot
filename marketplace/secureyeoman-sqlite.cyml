# SecureYeoman SQLite — Lightweight single-user variant for AGNOS marketplace
# Identical feature set to the full platform but uses SQLite instead of
# PostgreSQL — no sidecar database process, minimal footprint, zero-config
# persistent storage. Ideal for personal workstations and single-developer use.
#
# Same repo as SecureYeoman, different build target (SY_DB_BACKEND=sqlite).
#
# Status: Released — v0.5.0 (linux-x64 + linux-arm64)
# Source: https://github.com/MacCracken/SecureYeoman

[package]
name = "secureyeoman-sqlite"
version = "0.5.0"
description = "SecureYeoman SQLite — Lightweight single-user AI agent platform"
license = "GPL-3.0-only"
groups = ["server", "ai", "agents"]
release = 1
arch = "x86_64"

[source]
# Upstream prebuilt signed binary (sqlite target) from GitHub Actions CI.
# Release: https://github.com/MacCracken/SecureYeoman/releases
github_release = "MacCracken/SecureYeoman"
release_asset = "secureyeoman-*-sqlite-linux-x64"
sha256 = "3c985759faebb1c4509d6b20b9a61826aaaa3b4e861cbed86eaa237047574c59"

[depends]
runtime = [
    "glibc",
    "openssl",
    "sqlite",
    "zlib",
]
build = []  # prebuilt binary — no build toolchain required

[marketplace]
category = "ai-platform"
runtime = "native-binary"
publisher = "SecureYeoman"
tags = ["ai", "agents", "mcp", "orchestration", "security", "llm", "automation", "sqlite", "lightweight"]
min_agnos_version = "2026.3.11"

[marketplace.sandbox]
seccomp_mode = "desktop"
network_access = true
# AGNOS local services + external integrations (Slack, Discord, GitHub, etc.)
# External API access is gated per-integration by SecureYeoman's own RBAC
allowed_hosts = [
    "localhost",
    "127.0.0.1",
    # GitHub/GitLab APIs
    "api.github.com", "*.github.com",
    "gitlab.com", "*.gitlab.com",
    # AI providers (fallback when hoosh gateway is unreachable)
    "api.anthropic.com",
    "api.openai.com",
    "generativelanguage.googleapis.com",
    "api.deepseek.com",
    "api.mistral.ai",
    "api.groq.com",
    "api.x.ai",
    "openrouter.ai",
    # Messaging integrations
    "slack.com", "*.slack.com",
    "discord.com", "*.discord.com",
    "graph.microsoft.com",
    "api.telegram.org",
    # Productivity integrations
    "api.notion.com",
    "api.linear.app",
    "*.atlassian.net",
    # Vector store backends
    "*.qdrant.io",
]
data_dir = "~/.local/share/secureyeoman-sqlite/"

[[marketplace.sandbox.landlock]]
path = "~/.local/share/secureyeoman-sqlite/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/tmp"
access = "rw"

# Font access for dashboard rendering
[[marketplace.sandbox.landlock]]
path = "/usr/share/fonts"
access = "ro"

# Wayland socket
[[marketplace.sandbox.landlock]]
path = "/run/user/"
access = "ro"

# IPC with AGNOS agent runtime (daimon)
[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

[marketplace.services]
# SecureYeoman SQLite exposes: core API (18789), dashboard (3000), MCP service (3001)
ports = [18789, 3000, 3001]
# Uses AGNOS LLM Gateway (hoosh) and Agent Runtime (daimon)
depends_on = ["llm-gateway", "agent-runtime"]

[marketplace.wayland]
requirements = ["core", "xdg-shell"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = """
# Install the prebuilt signed binary (sqlite target)
mkdir -p $PKG/usr/lib/secureyeoman-sqlite/bin
install -Dm755 secureyeoman-*-sqlite-linux-x64 $PKG/usr/lib/secureyeoman-sqlite/bin/secureyeoman-sqlite

# Symlink into PATH
mkdir -p $PKG/usr/bin
ln -sf /usr/lib/secureyeoman-sqlite/bin/secureyeoman-sqlite $PKG/usr/bin/secureyeoman-sqlite

# Desktop entry for aethersafha (opens dashboard)
mkdir -p $PKG/usr/share/applications
cat > $PKG/usr/share/applications/secureyeoman-sqlite.desktop << 'EOF'
[Desktop Entry]
Name=SecureYeoman (SQLite)
Comment=Sovereign AI agent platform — lightweight SQLite edition
GenericName=AI Platform
Exec=secureyeoman-sqlite --serve
Icon=secureyeoman
Terminal=false
Type=Application
Categories=Development;ArtificialIntelligence;
StartupNotify=true
StartupWMClass=secureyeoman-sqlite
EOF

# Systemd service unit for headless/server mode
mkdir -p $PKG/usr/lib/systemd/user
cat > $PKG/usr/lib/systemd/user/secureyeoman-sqlite.service << 'EOF'
[Unit]
Description=SecureYeoman AI Agent Platform (SQLite)
After=network.target agnos-llm-gateway.service agnos-agent-runtime.service
Wants=agnos-llm-gateway.service agnos-agent-runtime.service

[Service]
Type=simple
ExecStart=/usr/lib/secureyeoman-sqlite/bin/secureyeoman-sqlite --serve
Environment=AGNOS_GATEWAY_URL=http://127.0.0.1:8088
Environment=AGNOS_RUNTIME_URL=http://127.0.0.1:8090
Environment=SECUREYEOMAN_DATA_DIR=%h/.local/share/secureyeoman-sqlite
Environment=SY_DB_BACKEND=sqlite
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
