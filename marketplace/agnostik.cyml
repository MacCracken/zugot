# Agnostik — shared types and domain primitives for AGNOS
# Core type vocabulary: agent identity, sandbox config, security policies,
# telemetry, LLM types, audit chains, and error handling.
# Consumed via `[deps.agnostik]` git deps in downstream cyrius.cyml.
#
# Name: Agnostik (agnostic — OS-agnostic shared types)
# Lang: Cyrius (was a Rust crate through 0.96.x; 1.x is the Cyrius rewrite)
#
# Status: Released — v1.2.2.

[package]
name = "agnostik"
version = "1.2.2"
description = "Agnostik — shared types and domain primitives for AGNOS"
license = "GPL-3.0-only"
groups = ["library", "types", "cyrius"]
release = 1
arch = "any"

[source]
github_release = "MacCracken/agnostik"
release_asset = "agnostik-*-src.tar.gz"
sha256 = "fa572a583c6e5970b92ea92cd5a761b149fb7e3005d62a46fe9a500087e58f5f"

[depends]
runtime = []
build = ["cyrius"]

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["types", "agent", "sandbox", "security", "telemetry", "audit", "llm", "rust"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = "cyrius build"
check = "cyrius test"
install = """
mkdir -p $PKG/usr/lib/agnostik
[ -f cyrius.cyml ] && cp cyrius.cyml $PKG/usr/lib/agnostik/
[ -f VERSION ]     && cp VERSION     $PKG/usr/lib/agnostik/
[ -d src ]         && cp -r src      $PKG/usr/lib/agnostik/
[ -d dist ]        && cp -r dist     $PKG/usr/lib/agnostik/
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
