# Nous — Package resolver for AGNOS
# Dependency resolution for system, marketplace, and community packages.
#
# Name: Nous (Greek: νοῦς — mind, intellect)
# Bin: nous
# Lang: Cyrius (was a Rust crate through 0.x; 1.x is the Cyrius rewrite)
#
# Status: Released — v1.2.5.

[package]
name = "nous"
version = "1.2.5"
description = "Nous — package resolver for AGNOS (system, marketplace, community)"
license = "GPL-3.0-only"
groups = ["library", "package-management", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/nous"
release_asset = "nous-1.2.5-x86_64-linux"
sha256 = "3d3b61d642fab16c72bff66e106d3e043fff7c8cd224e1a93033cd9bff5e9e3a"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["resolver", "dependency", "package", "cyrius"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = ""
check = ""
install = """
# 1.2.x ships a bare prebuilt binary asset (nous-<version>-x86_64-linux),
# not a tarball. Locate it by glob; fall back to a plain `nous`.
mkdir -p $PKG/usr/bin
BIN=$(find . -maxdepth 1 -type f -name 'nous-*-x86_64-linux' | head -1)
if [ -n "$BIN" ]; then
    install -Dm755 "$BIN" $PKG/usr/bin/nous
elif [ -f nous ]; then
    install -Dm755 nous $PKG/usr/bin/nous
fi
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
