# Kavach — Sandbox execution framework for the AGNOS ecosystem
# Backend abstraction, strength scoring (0-100), policy engine, credential
# proxy, lifecycle FSM. Extracted from SecureYeoman.
#
# Name: Kavach (Sanskrit: कवच — armor, shield)
# Bin: kavach
# Lang: Cyrius (was a Rust crate through 2.x; 3.x is the Cyrius rewrite)
#
# Status: Released — v3.4.2.

[package]
name = "kavach"
version = "3.4.2"
description = "Kavach — Sandbox execution framework (8 backends, strength scoring, policy engine)"
license = "GPL-3.0-only"
groups = ["library", "security", "sandbox", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/kavach"
release_asset = "kavach-*-x86_64-linux"
sha256 = "0df872cf2a525d8666c7a45e356ec74aef98f119517b3db369a0a278d7192cee"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["sandbox", "security", "isolation", "gvisor", "firecracker", "wasm", "sgx", "sev", "rust"]
min_agnos_version = "2026.3.21"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = ""
check = ""
install = """
mkdir -p $PKG/usr/bin
install -Dm755 kavach-*-x86_64-linux $PKG/usr/bin/kavach
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
