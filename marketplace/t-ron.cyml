# T-RON — Security/MCP integration for the AGNOS ecosystem
# (Sandbox-aware tool registry; bridges bote MCP dispatch and kavach
# sandbox policy enforcement.)
#
# Name: T-RON
# Bin: t-ron
# Lang: Cyrius (was a Rust crate through 0.90.x; 2.x is the Cyrius rewrite)
#
# Status: Released — v2.1.6.

[package]
name = "t-ron"
version = "2.1.6"
description = "T-Ron — MCP security monitor (auditing, rate limiting, injection detection, correlation)"
license = "GPL-3.0-only"
groups = ["library", "security", "mcp", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/t-ron"
release_asset = "t-ron-*-x86_64-linux"
sha256 = "5785bced371761bdcad0b11174c45e1a7649453b114855e99bb5a978e5ff6c93"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["mcp", "security", "audit", "firewall", "agent", "injection", "rate-limit", "correlation", "safety", "rust"]
min_agnos_version = "2026.3.24"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = ""
check = ""
install = """
mkdir -p $PKG/usr/bin
install -Dm755 t-ron-*-x86_64-linux $PKG/usr/bin/t-ron
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
