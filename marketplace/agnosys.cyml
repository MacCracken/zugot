# Agnosys — AGNOS kernel interface
# Cyrius bindings for Linux syscalls, Landlock, seccomp, udev, TPM, LUKS,
# dm-verity. Consumed via `[deps.agnosys]` git deps in downstream cyrius.cyml.
#
# Name: Agnosys (agnos + sys — toward knowledge of the system)
# Lang: Cyrius (was a Rust crate through 0.97.x; 1.x is the Cyrius rewrite)
#
# Status: Released — v1.0.2.

[package]
name = "agnosys"
version = "1.0.2"
description = "Agnosys — AGNOS kernel interface"
license = "GPL-3.0-only"
groups = ["library", "system", "kernel", "cyrius"]
release = 1
arch = "any"

[source]
github_release = "MacCracken/agnosys"
release_asset = "agnosys-*-src.tar.gz"
sha256 = "71ebd125f63f8c4cdacdd0e8f31b41c8f1c7aaa093f806dfe5209aa5eb74c3b7"

[depends]
runtime = ["glibc"]
build = ["cyrius"]

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["kernel", "syscall", "linux", "security", "landlock", "seccomp", "tpm", "udev", "rust"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = "cyrius build"
check = "cyrius test"
install = """
mkdir -p $PKG/usr/lib/agnosys
[ -f cyrius.cyml ] && cp cyrius.cyml $PKG/usr/lib/agnosys/
[ -f VERSION ]     && cp VERSION     $PKG/usr/lib/agnosys/
[ -d src ]         && cp -r src      $PKG/usr/lib/agnosys/
[ -d dist ]        && cp -r dist     $PKG/usr/lib/agnosys/
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
