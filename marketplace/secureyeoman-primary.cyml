# SecureYeoman Primary — Full primary server for AGNOS marketplace
# The complete SecureYeoman platform configured for primary/coordinator role:
# runs all orchestration services, the full dashboard, the PostgreSQL backend,
# the MCP gateway, and accepts connections from Lite and Edge worker nodes.
# Intended for deployment as the central hub in a multi-node setup.
#
# This is functionally identical to secureyeoman.toml but with explicit
# primary-mode configuration (SY_ROLE=primary) and additional peer networking
# allowances for accepting inbound worker connections.
#
# Status: Released — v0.5.0 (linux-x64 + linux-arm64)
# Source: https://github.com/MacCracken/SecureYeoman

[package]
name = "secureyeoman-primary"
version = "0.5.0"
description = "SecureYeoman Primary — Full primary server with multi-node orchestration"
license = "GPL-3.0-only"
groups = ["server", "ai", "agents"]
release = 1
arch = "x86_64"

[source]
# Upstream prebuilt signed binary — same base binary as the main release;
# the primary role is set via env (SY_ROLE=primary). Installed directly.
# Release: https://github.com/MacCracken/SecureYeoman/releases
github_release = "MacCracken/SecureYeoman"
release_asset = "secureyeoman-0.5.0-linux-x64"
sha256 = "2ecfcb60a95fd1a4bfd8a543e6ba061250c6844c37893f5e4537b3fc51b54d16"

[depends]
runtime = [
    "glibc",
    "openssl",
    "sqlite",
    "postgresql17",
    "zlib",
]
build = []  # prebuilt binary — no build toolchain required

[marketplace]
category = "ai-platform"
runtime = "native-binary"
publisher = "SecureYeoman"
tags = ["ai", "agents", "mcp", "orchestration", "security", "llm", "automation", "enterprise", "primary", "multi-node"]
min_agnos_version = "2026.3.11"
flagship = false

[marketplace.sandbox]
seccomp_mode = "desktop"
network_access = true
# AGNOS local services + external integrations + inbound worker connections
allowed_hosts = [
    "localhost",
    "127.0.0.1",
    # Inbound worker nodes (LAN/VPN)
    "*.local",
    # GitHub/GitLab APIs
    "api.github.com", "*.github.com",
    "gitlab.com", "*.gitlab.com",
    # AI providers (fallback when hoosh gateway is unreachable)
    "api.anthropic.com",
    "api.openai.com",
    "generativelanguage.googleapis.com",
    "api.deepseek.com",
    "api.mistral.ai",
    "api.groq.com",
    "api.x.ai",
    "openrouter.ai",
    # Messaging integrations
    "slack.com", "*.slack.com",
    "discord.com", "*.discord.com",
    "graph.microsoft.com",
    "api.telegram.org",
    # Productivity integrations
    "api.notion.com",
    "api.linear.app",
    "*.atlassian.net",
    # Vector store backends
    "*.qdrant.io",
]
data_dir = "~/.local/share/secureyeoman-primary/"

[[marketplace.sandbox.landlock]]
path = "~/.local/share/secureyeoman-primary/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/tmp"
access = "rw"

# Font access for dashboard rendering
[[marketplace.sandbox.landlock]]
path = "/usr/share/fonts"
access = "ro"

# Wayland socket
[[marketplace.sandbox.landlock]]
path = "/run/user/"
access = "ro"

# IPC with AGNOS agent runtime (daimon)
[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

# PostgreSQL data directory
[[marketplace.sandbox.landlock]]
path = "~/.local/share/secureyeoman-primary/pgdata/"
access = "rw"

[marketplace.services]
# Primary server: core API (18789), dashboard (3000), MCP gateway (3001), worker ingress (18790)
ports = [18789, 18790, 3000, 3001]
depends_on = ["llm-gateway", "agent-runtime"]

[marketplace.wayland]
requirements = ["core", "xdg-shell"]

[build]
pre_build = ""
configure = ""
make = ""
check = ""
install = """
# Install the prebuilt signed binary (base binary; primary role set via env)
mkdir -p $PKG/usr/lib/secureyeoman-primary/bin
install -Dm755 secureyeoman-0.5.0-linux-x64 $PKG/usr/lib/secureyeoman-primary/bin/secureyeoman-primary

# Symlink into PATH
mkdir -p $PKG/usr/bin
ln -sf /usr/lib/secureyeoman-primary/bin/secureyeoman-primary $PKG/usr/bin/secureyeoman-primary

# Desktop entry for aethersafha
mkdir -p $PKG/usr/share/applications
cat > $PKG/usr/share/applications/secureyeoman-primary.desktop << 'EOF'
[Desktop Entry]
Name=SecureYeoman Primary
Comment=Sovereign AI agent platform — primary server mode
GenericName=AI Platform
Exec=secureyeoman-primary --serve
Icon=secureyeoman
Terminal=false
Type=Application
Categories=Development;ArtificialIntelligence;
StartupNotify=true
StartupWMClass=secureyeoman-primary
EOF

# Systemd service unit for primary server mode
mkdir -p $PKG/usr/lib/systemd/user
cat > $PKG/usr/lib/systemd/user/secureyeoman-primary.service << 'EOF'
[Unit]
Description=SecureYeoman AI Agent Platform — Primary Server
After=network.target agnos-llm-gateway.service agnos-agent-runtime.service postgresql.service
Wants=agnos-llm-gateway.service agnos-agent-runtime.service

[Service]
Type=simple
ExecStart=/usr/lib/secureyeoman-primary/bin/secureyeoman-primary --serve
Environment=AGNOS_GATEWAY_URL=http://127.0.0.1:8088
Environment=AGNOS_RUNTIME_URL=http://127.0.0.1:8090
Environment=SECUREYEOMAN_DATA_DIR=%h/.local/share/secureyeoman-primary
Environment=SY_ROLE=primary
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
