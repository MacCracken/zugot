# Sigil — System-wide trust verification for AGNOS
# Ed25519 signing, SHA-256/512 integrity, HMAC, HKDF, AES-256-GCM,
# publisher keyring, revocation, key rotation, batch verification, key
# pinning, trust delegation, cross-signing, CRL distribution, audit logging.
#
# Name: Sigil (Latin: seal)
# Bin: sigil (smoke verifier CLI; the library is consumed via `[deps.sigil]`)
# Lang: Cyrius (was a Rust crate through 2.4.x; 2.9.x is the Cyrius rewrite)
#
# Status: Released — v3.4.3.

[package]
name = "sigil"
version = "3.4.3"
description = "Sigil — system-wide trust verification (signing, integrity, revocation, delegation)"
license = "GPL-3.0-only"
groups = ["library", "security", "crypto", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/sigil"
release_asset = "sigil-*.tar.gz"
sha256 = "13f39680ed7c2b4c8b9d08962c984456c5fb920147417925a449dfe73781e63e"

[depends]
runtime = ["glibc"]
build = ["cyrius"]

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["trust", "verification", "signing", "integrity", "revocation", "ed25519", "security", "crypto", "rust"]
min_agnos_version = "2026.3.24"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = "cyrius build"
check = "cyrius test"
install = """
mkdir -p $PKG/usr/bin
cp build/sigil $PKG/usr/bin/sigil
chmod +x $PKG/usr/bin/sigil
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
