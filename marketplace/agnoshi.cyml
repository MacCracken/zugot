# Agnoshi — AI-native natural language shell for AGNOS
# Natural language command interpretation, pipeline construction,
# context-aware completions, LLM-powered assistance.
#
# Name: Agnoshi (agnostic + shell)
# Bin: agnsh (binary), agnoshi (project name)
# Lang: Cyrius (was Rust through 0.90.x; 1.0+ is the Cyrius rewrite)
#
# Status: Released — v1.7.0. Approval workflow, interactive shell, P(-1)
#   audit with ADR-006 + CI lint shield, both x86_64 + aarch64 static
#   binaries. (Asset is the prebuilt agnsh-<version>-x86_64-linux ELF.)

[package]
name = "agnoshi"
version = "1.7.0"
description = "Agnoshi — AI-native natural language shell for AGNOS"
license = "GPL-3.0-only"
groups = ["tool", "shell", "ai", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/agnoshi"
# Release workflow ships `agnsh-${TAG}-x86_64-linux` (per
# `.github/workflows/release.yml` — the v1.1.0 fix that renamed the
# entry from src/main.cyr → src/agnsh.cyr also retitled the asset).
release_asset = "agnsh-*-x86_64-linux"
# Verified against the agnsh-1.7.0-x86_64-linux release asset.
sha256 = "9690f65ef23220ef71fccecc02f2aa823057aeee32afb633a81aff5fc4073785"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "shell"
runtime = "native-binary"
publisher = "AGNOS"
# Dropped "rust" tag — agnoshi is Cyrius-native since 1.0.0 (the
# rust-old/ tree is preserved for benchmark comparison only).
tags = ["shell", "ai", "natural-language", "cli", "terminal", "cyrius"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "desktop"
network_access = true
allowed_hosts = ["localhost", "127.0.0.1"]
# Data dir is mixed by convention: ~/.agnsh_history + ~/.agnsh_audit.log
# (per agnsh.1) live at $HOME root; ~/.agnoshi/checkpoints/ holds
# rollback backups for destructive ops (per ADR / SECURITY model).
data_dir = "~/.agnoshi/"

[[marketplace.sandbox.landlock]]
path = "~/.agnoshi/"
access = "rw"

# Allow read+write to history + audit log files at HOME root.
[[marketplace.sandbox.landlock]]
path = "~/.agnsh_history"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "~/.agnsh_audit.log"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

[build]
make = ""
check = ""
# Asset is the prebuilt static ELF named `agnsh-1.7.0-x86_64-linux`
# from the GitHub release; install path uses the canonical bin name
# `agnsh` (per docs/agnsh.1).
install = """
mkdir -p $PKG/usr/bin
install -Dm755 agnsh-*-x86_64-linux $PKG/usr/bin/agnsh
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
