# Agnoshi — AI-native natural language shell for AGNOS
# Natural language command interpretation, pipeline construction,
# context-aware completions, LLM-powered assistance.
#
# Name: Agnoshi (agnostic + shell)
# Bin: agnoshi
# Lang: Cyrius (was Rust through 0.x; 1.x is the Cyrius rewrite)
#
# Status: Released — v1.0.0.

[package]
name = "agnoshi"
version = "1.0.0"
description = "Agnoshi — AI-native natural language shell for AGNOS"
license = "GPL-3.0-only"
groups = ["tool", "shell", "ai", "cyrius"]
release = 1
arch = "x86_64"

[source]
github_release = "MacCracken/agnoshi"
release_asset = "agnoshi"
sha256 = "af7aae409c25902bc498155df23444ae062adb0d98ad2bc7dce63af809f0e97d"

[depends]
runtime = ["glibc"]
build = []

[marketplace]
category = "shell"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["shell", "ai", "natural-language", "cli", "terminal", "rust"]
min_agnos_version = "2026.3.22"

[marketplace.sandbox]
seccomp_mode = "desktop"
network_access = true
allowed_hosts = ["localhost", "127.0.0.1"]
data_dir = "~/.agnoshi/"

[[marketplace.sandbox.landlock]]
path = "~/.agnoshi/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "rw"

[build]
make = ""
check = ""
install = """
mkdir -p $PKG/usr/bin
install -Dm755 agnoshi $PKG/usr/bin/agnoshi
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
