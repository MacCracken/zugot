# Agnostic — Multi-domain AI agent platform for AGNOS marketplace
# Generalized agent crew orchestration with domain presets (quality, security,
# performance, data-engineering, devops, design, software-engineering).
# Built with Python/CrewAI; packaged as .agnos-agent via Docker container.
#
# Status: Ready — 23 MCP tools, 14 agnoshi intents, A2A delegation, crew presets.
# v2026.3.17-1: +list_crews (GET /crews), +cancel_crew (POST /crews/{id}/cancel),
#   dashboard.js API path fix, MCP enabled, dark theme, branding → "Agnostic Agent System"
# v2026.3.17-2: patch release — see GitHub release notes.

[package]
name = "agnostic"
version = "2026.3.18"
description = "Agnostic — Multi-domain AI agent platform with crew orchestration"
license = "GPL-3.0-only"
groups = ["server", "agent-automation", "ai-agents", "python"]
release = 2
arch = "x86_64"

[source]
# Python application, built by GitHub Actions CI.
# Release: https://github.com/MacCracken/agnostic/releases
# Asset: agnostic-*-py3-none-any.whl (~506 KB)
local = true
build_dir = "."
github_release = "MacCracken/agnostic"
release_asset = "agnostic-*-py3-none-any.whl"
sha256 = ""  # TODO: populate from release tarball

[depends]
runtime = [
    "glibc",
    "python3",
    "openssl",
    "sqlite",
    "libffi",
    "zlib",
]
build = [
    "python3",
    "pip",
    "openssl-dev",
    "libffi-dev",
    "zlib-dev",
]

[marketplace]
category = "developer-tools"
runtime = "python-container"
publisher = "Agnostic"
tags = ["agent-automation", "ai-agents", "crewai", "crew-orchestration", "multi-domain", "security-compliance", "performance", "devops"]
min_agnos_version = "2026.3.17"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = true
allowed_hosts = [
    "localhost",
    "127.0.0.1",
    # LLM Gateway (hoosh) and Agent Runtime (daimon)
    # External hosts restricted to AGNOS gateway — no direct LLM provider access needed
]
data_dir = "~/.local/share/agnostic/"

[[marketplace.sandbox.landlock]]
path = "~/.local/share/agnostic/"
access = "rw"

[[marketplace.sandbox.landlock]]
path = "/tmp"
access = "rw"

# PostgreSQL data directory (embedded)
[[marketplace.sandbox.landlock]]
path = "/data"
access = "rw"

# Python packages and runtime (read-only)
[[marketplace.sandbox.landlock]]
path = "/usr/lib/python3"
access = "ro"

[[marketplace.sandbox.landlock]]
path = "/usr/local/lib/python3"
access = "ro"

# IPC with AGNOS agent runtime
[[marketplace.sandbox.landlock]]
path = "/run/agnos/"
access = "ro"

[marketplace.services]
# Agnostic exposes a WebGUI on port 8000 (Chainlit + FastAPI)
ports = [8000]
# Requires AGNOS LLM Gateway (hoosh) and Agent Runtime (daimon)
depends_on = ["llm-gateway", "agent-runtime"]

[build]
pre_build = """
# Install Python dependencies
pip install --no-cache-dir -r requirements.txt
"""
configure = ""
make = "docker build -t agnostic ."
check = "python run_tests.py --unit"
install = """
# Agnostic runs as a container managed by daimon.
# Install the container image and systemd-style service unit.
mkdir -p $PKG/usr/lib/agnostic
mkdir -p $PKG/etc/agnostic

# Copy default configuration
cp .env.example $PKG/etc/agnostic/env.defaults

# Desktop entry for aethersafha (opens WebGUI in browser)
mkdir -p $PKG/usr/share/applications
cat > $PKG/usr/share/applications/agnostic.desktop << 'EOF'
[Desktop Entry]
Name=Agnostic
Comment=AI-driven multi-agent automation platform
GenericName=Agent Automation
Exec=xdg-open http://localhost:8000
Icon=agnostic
Terminal=false
Type=Application
Categories=Development;Testing;
StartupNotify=true
EOF
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
