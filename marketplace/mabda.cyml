# Mabda — GPU foundation crate for AGNOS
# Shared GPU abstractions: device lifecycle, buffers, compute, textures,
# profiling, capability detection. Consumed via `[deps.mabda]` git deps
# in downstream cyrius.cyml. Recipe ships the source tree for inspection;
# `cyrius build` only produces a smoke-test binary (build/mabda_smoke).
#
# Name: Mabda (Arabic: origin/foundation)
# Lang: Cyrius (was a Rust crate through 1.x; 2.x is the Cyrius rewrite)
#
# Status: Released — v2.5.0.

[package]
name = "mabda"
version = "2.5.0"
description = "Mabda — GPU foundation crate"
license = "GPL-3.0-only"
groups = ["library", "graphics", "cyrius"]
release = 1
arch = "any"

[source]
github_release = "MacCracken/mabda"
release_asset = "mabda-*-src.tar.gz"
sha256 = "bd4d05bf647c547d32a39661d09a8cb09894590ec0dae309f7ac472c424696c1"

[depends]
runtime = []
build = ["cyrius"]

[marketplace]
category = "library"
runtime = "native-binary"
publisher = "AGNOS"
tags = ["gpu", "wgpu", "graphics", "foundation", "rust"]
min_agnos_version = "2026.3.24"

[marketplace.sandbox]
seccomp_mode = "basic"
network_access = false

[build]
make = "cyrius build"
check = "cyrius test"
install = """
mkdir -p $PKG/usr/lib/mabda
[ -f cyrius.cyml ] && cp cyrius.cyml $PKG/usr/lib/mabda/
[ -f VERSION ]     && cp VERSION     $PKG/usr/lib/mabda/
[ -d src ]         && cp -r src      $PKG/usr/lib/mabda/
[ -d dist ]        && cp -r dist     $PKG/usr/lib/mabda/
"""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
