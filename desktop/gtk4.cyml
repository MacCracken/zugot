# gtk4 — GTK4 toolkit for building graphical user interfaces
#
# BLFS

[package]
name = "gtk4"
version = "4.22.2"
description = "gtk4 — GTK4 widget toolkit for graphical applications"
license = "LGPL-2.0-only"
groups = ["desktop", "libs"]
release = 1
arch = "x86_64"

[source]
url = "https://download.gnome.org/sources/gtk/4.22/gtk-4.22.2.tar.xz"
sha256 = "b1c987370a0c30780cde351bdbee02eef816728f1c1c2ec7c8093281c0709ee8"
patches = []

[depends]
runtime = ["glibc", "glib", "cairo", "pango", "harfbuzz", "wayland", "wayland-protocols", "libxkbcommon", "mesa", "libepoxy", "graphene", "gdk-pixbuf"]
build = ["gcc", "make", "pkgconf", "meson", "ninja"]

[build]
pre_build = ""
configure = """
mkdir -p build && cd build && \
meson setup .. --prefix=/usr --buildtype=release
"""
make = "cd build && ninja -j$(nproc)"
check = "cd build && meson test || true"
install = "cd build && DESTDIR=$PKG ninja install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
