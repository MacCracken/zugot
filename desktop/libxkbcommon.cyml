# libxkbcommon — Keyboard keymap handling library
# Compiles XKB keymaps for Wayland compositors
#
# BLFS

[package]
name = "libxkbcommon"
version = "1.11.0"
description = "libxkbcommon — Keyboard keymap handling library"
license = "MIT"
groups = ["desktop", "graphics"]
release = 1
arch = "x86_64"

[source]
url = "https://github.com/xkbcommon/libxkbcommon/archive/refs/tags/xkbcommon-1.11.0.tar.gz"
sha256 = "78a6b14f16e9a55025978c252e53ce9e16a02bfdb929550b9a0db5af87db7e02"
patches = []

[depends]
runtime = ["glibc", "wayland", "wayland-protocols"]
build = ["gcc", "make", "pkgconf", "meson", "ninja"]

[build]
pre_build = ""
configure = """
mkdir -p build && cd build && \
meson setup .. --prefix=/usr --buildtype=release \
  -Denable-wayland=true \
  -Denable-x11=false \
  -Denable-docs=false
"""
make = "cd build && ninja -j$(nproc)"
check = "cd build && meson test || true"
install = "cd build && DESTDIR=$PKG ninja install"
post_install = ""

[security]
hardening = ["pie", "fullrelro", "fortify", "stackprotector", "bindnow"]
cflags = "-O2 -pipe"
ldflags = "-Wl,--as-needed"
